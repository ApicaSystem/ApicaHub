      "queriesList": [
        {
          "chart_type": "line",
          "data_source_name": "Ascent Metrics",
          "query": "sum(slo:total_event_rate:5m)&duration=1.000h&step=5m",
          "schema": "slo:total_event_rate:5m",
          "options": {
            "description": "Total SLI events",
            "order": 1,
            "plot": {
              "x": "timestamp",
              "xLabel": "Timestamp",
              "y": [
                "value"
              ],
              "yLabel": "Total Events"
            }
          },
          "name": "Total Events"
        },
        {
          "chart_type": "line",
          "data_source_name": "Ascent Metrics",
          "query": "sum(slo:good_event_rate:5m)&duration=1.000h&step=5m",
          "schema": "slo:good_event_rate:5m",
          "options": {
            "description": "Successful SLI events",
            "order": 2,
            "plot": {
              "x": "timestamp",
              "xLabel": "Timestamp",
              "y": [
                "value"
              ],
              "yLabel": "Successful Events"
            }
          },
          "name": "Successful Events"
        },
        {
          "chart_type": "line",
          "data_source_name": "Ascent Metrics",
          "query": "(sum(slo:total_event_rate:5m) - sum(slo:good_event_rate:5m))&duration=1.000h&step=5m",
          "schema": "slo:total_event_rate:5m",
          "options": {
            "description": "Error SLI events",
            "order": 3,
            "plot": {
              "x": "timestamp",
              "xLabel": "Timestamp",
              "y": [
                "value"
              ],
              "yLabel": "Error Events"
            }
          },
          "name": "Error Events"
        },
        {
          "chart_type": "line",
          "data_source_name": "Ascent Metrics",
          "query": "(sum(slo:good_event_rate:5m) / sum(slo:total_event_rate:5m))&duration=1.000h&step=5m",
          "schema": "slo:good_event_rate:5m",
          "options": {
            "description": "SLI success ratio",
            "order": 4,
            "upperLimit": "1",
            "plot": {
              "x": "timestamp",
              "xLabel": "Timestamp",
              "y": [
                "value"
              ],
              "yLabel": "Success Rate"
            }
          },
          "name": "SLI Success Rate"
        },
        {
          "chart_type": "line",
          "data_source_name": "Ascent Metrics",
          "query": "((sum(slo:total_event_rate:5m) - sum(slo:good_event_rate:5m)) / sum(slo:total_event_rate:5m))&duration=1.000h&step=5m",
          "schema": "slo:total_event_rate:5m",
          "options": {
            "description": "Error budget burn rate",
            "order": 5,
            "plot": {
              "x": "timestamp",
              "xLabel": "Timestamp",
              "y": [
                "value"
              ],
              "yLabel": "Burn Rate"
            }
          },
          "name": "Error Budget Burn Rate"
        },
        {
          "chart_type": "line",
          "data_source_name": "Ascent Metrics",
          "query": "1 - ((sum(slo:total_event_rate:5m) - sum(slo:good_event_rate:5m)) / sum(slo:total_event_rate:5m))&duration=1.000h&step=5m",
          "schema": "slo:total_event_rate:5m",
          "options": {
            "description": "Remaining error budget",
            "order": 6,
            "plot": {
              "x": "timestamp",
              "xLabel": "Timestamp",
              "y": [
                "value"
              ],
              "yLabel": "Remaining Budget"
            }
          },
          "name": "Error Budget Remaining"
        },
        {
          "chart_type": "counter",
          "data_source_name": "Ascent Metrics",
          "query": "(sum(slo:good_event_rate:5m) / sum(slo:total_event_rate:5m)) * 100",
          "schema": "",
          "options": {
            "plot": {
              "x": "timestamp",
              "y": [
                "value"
              ]
            },
            "order": 7
          },
          "name": "SLO Health"
        },
        {
          "chart_type": "counter",
          "data_source_name": "Ascent Metrics",
          "query": "(\n(sum(slo:total_event_rate:5m) - sum(slo:good_event_rate:5m))\n/\nsum(slo:total_event_rate:5m)\n) * 100",
          "schema": "",
          "options": {
            "plot": {
              "x": "timestamp",
              "y": [
                "value"
              ]
            },
            "order": 8
          },
          "name": "Error Rate (%)"
        },
        {
          "chart_type": "counter",
          "data_source_name": "Ascent Metrics",
          "query": "(\n(\n(sum(slo:total_event_rate:5m) - sum(slo:good_event_rate:5m))\n/\nsum(slo:total_event_rate:5m)\n)\n/\n(1 - 0.999)\n) * 100",
          "schema": "",
          "options": {
            "plot": {
              "x": "timestamp",
              "y": [
                "value"
              ]
